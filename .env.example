# Copy to .env to override defaults. All variables are prefixed FDP_.
FDP_LOG_LEVEL=INFO
FDP_DECISION_THRESHOLD=0.5
FDP_MODEL_PATH=models/model.pkl
FDP_METRICS_PATH=models/metrics.json

# Persistence (RDS). Empty => prediction logging disabled (null repository).
FDP_DATABASE_URL=
# e.g. postgresql+psycopg://fdp:fdp@localhost:5432/fdp

# Cache (Redis). Empty => caching disabled (null cache).
FDP_REDIS_URL=
# e.g. redis://localhost:6379/0
FDP_CACHE_TTL_SECONDS=300

# Observability (CloudWatch custom metrics). Empty namespace => no-op.
FDP_CLOUDWATCH_NAMESPACE=
FDP_AWS_REGION=us-east-1
