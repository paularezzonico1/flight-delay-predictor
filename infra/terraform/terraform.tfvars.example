# Copy to terraform.tfvars and fill in. Do NOT commit real secrets.
# db_password is best supplied via the environment instead:
#   export TF_VAR_db_password='...'

name   = "fdp"
region = "us-east-1"

# Pushed to ECR by CI; tag with the git SHA in real deploys.
image_uri = "123456789012.dkr.ecr.us-east-1.amazonaws.com/flight-delay-predictor:latest"

# Sizing
instance_type    = "t3.small"
min_size         = 2
max_size         = 6
desired_capacity = 2

# Database (password via TF_VAR_db_password)
db_instance_class = "db.t3.micro"
db_name           = "fdp"
db_username       = "fdp"

# Optional: email for SNS alarm notifications
alarm_email = ""
